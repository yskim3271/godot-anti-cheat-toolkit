[configuration]

entry_symbol = "anti_cheat_native_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]

windows.editor.x86_64 = "res://addons/anti_cheat_toolkit/bin/anti_cheat_native.windows.template_debug.x86_64.dll"
windows.debug.x86_64 = "res://addons/anti_cheat_toolkit/bin/anti_cheat_native.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/anti_cheat_toolkit/bin/anti_cheat_native.windows.template_release.x86_64.dll"
